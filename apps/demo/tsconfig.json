{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@snap-machines/core": ["../../packages/snap-machines/src/index.ts"],
      "@snap-machines/core/*": ["../../packages/snap-machines/src/*"],
      "@snap-machines/react": ["../../packages/react/src/index.ts"]
    }
  },
  "include": ["src"]
}
